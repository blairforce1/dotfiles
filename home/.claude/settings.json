{
  "env": {
    "CLAUDE_CODE_DISABLE_MOUSE_CLICKS": "1"
  },
  "permissions": {
    "defaultMode": "plan"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/herdr-agent-state.sh\" session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline-command.sh\""
  },
  "extraKnownMarketplaces": {
    "blairforce1": {
      "source": {
        "source": "git",
        "url": "git@github.com:blairforce1/claude-plugins"
      }
    }
  },
  "tui": "fullscreen",
  "editorMode": "normal"
}
